{
  "name": "many2go",
  "version": "1.0.0",
  "description": "MANY2GO Super App - Travel platform",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:api": "pnpm --filter @many2go/api build",
    "start:api": "pnpm --filter @many2go/api start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "pnpm --filter @many2go/api db:migrate",
    "db:generate": "pnpm --filter @many2go/api db:generate",
    "db:studio": "pnpm --filter @many2go/api db:studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
