datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  CUSTOMER
  AGENT
  ADMIN
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTED
  BOOKED
  CLOSED
}

enum ItineraryStatus {
  DRAFT
  FINALIZED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          UserRole  @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  customerLeads   Lead[]      @relation("CustomerLeads")
  agentLeads      Lead[]      @relation("AgentLeads")
  itineraries     Itinerary[]
  sentMessages    Message[]   @relation("SentMessages")
  receivedMessages Message[]  @relation("ReceivedMessages")
  reminders       Reminder[]
  revenues        Revenue[]
}

model Lead {
 id String @id @default(uuid())
 customerId String
 agentId String?
 name String?
 status LeadStatus @default(NEW)
 notes String?
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt

 // Call Tracking Fields
 callStatus String? @default("PENDING")
 callDate DateTime?
 callTime String?

 // Follow-up Fields
 followUpDate DateTime?
 followUpTime String?
 followUpNote String?

 // Contact & Reference Fields
 phone String?
 cmNumber String?

 // Travel Details Fields
 destination String?
 travelMonth String?
 travelDate String?
 returnDate String?
 daysPlanned String?
 adults Int? @default(1)
 kids Int? @default(0)
 kidsAge String?
 mealsplan String?
 hotelCategory String?
 budget String?
 travelFrom String?
 passportStatus String?
 lastVacation String?
 remarks String?

 // Communication Tracking Flags
 whatsappCreated Boolean @default(false)
 itineraryShared Boolean @default(false)
 flightCostsSent Boolean @default(false)
 quoteSent Boolean @default(false)
 outcome String?

 // Relations
 customer User @relation("CustomerLeads", fields: [customerId], references: [id], onDelete: Cascade)
 agent User? @relation("AgentLeads", fields: [agentId], references: [id], onDelete: SetNull)
 reminders Reminder[]
}

model Itinerary {
  id          String            @id @default(uuid())
  userId      String
  title       String
  days        Json              // Array of days with activities
  status      ItineraryStatus   @default(DRAFT)
  pdfUrl      String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings    Booking[]
}

model Booking {
  id            String         @id @default(uuid())
  itineraryId   String
  status        BookingStatus  @default(PENDING)
  paidAmount    Float          @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  itinerary     Itinerary  @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  revenues      Revenue[]
}

model Offer {
  id          String    @id @default(uuid())
  title       String
  description String
  discount    Float     // Percentage or fixed amount
  imageUrl    String?
  expiresAt   DateTime
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Message {
  id            String    @id @default(uuid())
  senderId      String
  recipientId   String
  body          String
  readAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  sender        User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipient     User      @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)
}

model Reminder {
  id          String    @id @default(uuid())
  agentId     String
  leadId      String
  note        String
  dueAt       DateTime
  isDone      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  agent       User      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Revenue {
  id          String    @id @default(uuid())
  agentId     String
  bookingId   String
  amount      Float
  createdAt   DateTime  @default(now())

  // Relations
  agent       User      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([agentId, bookingId])
}
